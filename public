const API_URL = '';
let currentUser = null;
let currentToken = null;
let currentReportId = null;
let currentClients = [];
let currentClientId = null;

function init() {
    const token = localStorage.getItem('nuronis_token');
    if (token) {
        currentToken = token;
        const user = JSON.parse(localStorage.getItem('nuronis_user') || '{}');
        currentUser = user;
        showApp();
        loadDashboard();
    } else {
        showLogin();
    }
}

function showLogin() {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('login-screen').classList.add('active');
}

function showApp() {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('app-screen').classList.add('active');
    document.getElementById('user-name').textContent = currentUser?.nome || 'Gerente';
    document.getElementById('dash-name').textContent = currentUser?.nome?.split(' ')[0] || 'Gerente';
    showScreen('dashboard');
}

function logout() {
    localStorage.removeItem('nuronis_token');
    localStorage.removeItem('nuronis_user');
    currentUser = null;
    currentToken = null;
    showLogin();
}

document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const cpf = document.getElementById('cpf').value.replace(/\D/g, '');
    const senha = document.getElementById('senha').value;
    
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    
    try {
        const res = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cpf, senha })
        });
        
        const data = await res.json();
        
        if (res.ok) {
            currentToken = data.token;
            currentUser = data.user;
            localStorage.setItem('nuronis_token', data.token);
            localStorage.setItem('nuronis_user', JSON.stringify(data.user));
            showApp();
            loadDashboard();
            showToast(Bem-vindo, ${data.user.nome}!);
        } else {
            showToast(data.error || 'Erro no login', 'error');
        }
    } catch (err) {
        showToast('Erro de conexão', 'error');
    } finally {
        btn.disabled = false;
    }
});

function showScreen(screenName) {
    document.querySelectorAll('.content-screen').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    
    document.getElementById(${screenName}-screen)?.classList.add('active');
    document.querySelector([data-screen="${screenName}"])?.classList.add('active');
    
    if (screenName === 'dashboard') loadDashboard();
    if (screenName === 'reports') loadReports();
    if (screenName === 'ranking') loadRanking();
}

async function loadDashboard() {
    try {
        const res = await fetch('/api/dashboard', {
            headers: { 'Authorization': Bearer ${currentToken} }
        });
        const data = await res.json();
        
        if (res.ok) {
            document.getElementById('stat-relatorios').textContent = data.stats?.total_relatorios || 0;
            document.getElementById('stat-clientes').textContent = data.stats?.total_clientes || 0;
            document.getElementById('stat-contactados').textContent = data.stats?.contactados || 0;
            document.getElementById('stat-vendas').textContent = data.stats?.vendas || 0;
            document.getElementById('dash-tickets').textContent = ${data.stats?.total_tickets || 0} tickets;
            
            const progress = Math.min(100, ((data.stats?.total_tickets || 0) / 20) * 100);
            document.getElementById('progress-fill').style.width = ${progress}%;
            
            const reportsContainer = document.getElementById('recent-reports');
            if (data.reports && data.reports.length > 0) {
                reportsContainer.innerHTML = data.reports.slice(0, 3).map(r => `
                    <div class="report-card" onclick="openReport(${r.id}, '${r.nome}')">
                        <div class="report-card-header">
                            <span class="report-card-title">${r.nome}</span>
                            <span class="report-card-date">${formatDate(r.data_upload)}</span>
                        </div>
                        <div class="report-card-stats">
                            <span>👥 ${r.total_clientes} clientes</span>
                            <span>⏳ ${r.pendentes || 0} pendentes</span>
                        </div>
                    </div>
                `).join('');
            }
        }
    } catch (err) {
        console.error('Erro dashboard:', err);
    }
}

async function loadReports() {
    try {
        const res = await fetch('/api/reports', {
            headers: { 'Authorization': Bearer ${currentToken} }
        });
        const reports = await res.json();
        
        const container = document.getElementById('all-reports');
        if (reports.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <span>📭</span>
                    <p>Nenhum relatório ainda</p>
                    <small>Coloque seu primeiro relatório acima</small>
                </div>
            `;
        } else {
            container.innerHTML = reports.map(r => `
                <div class="report-card" onclick="openReport(${r.id}, '${r.nome}')">
                    <div class="report-card-header">
                        <span class="report-card-title">${r.nome}</span>
                        <span class="report-card-date">${formatDate(r.data_upload)}</span>
                    </div>
                    <div class="report-card-stats">
                        <span>👥 ${r.total_clientes} clientes</span>
                        <span>⏳ ${r.pendentes || 0} pendentes</span>
                    </div>
                </div>
            `).join('');
        }
    } catch (err) {
        console.error('Erro reports:', err);
    }
}

async function uploadReport() {
    const nome = document.getElementById('report-name').value.trim();
    const dados = document.getElementById('report-data').value.trim();
    
    if (!nome) return showToast('Dê um nome ao relatório', 'error');
    if (!dados) return showToast('Cole os dados do Excel', 'error');
    
    const linhas = dados.split('\n').filter(l => l.trim());
    const clientes = [];
    
    linhas.forEach(linha => {
        const partes = linha.split('|').map(p => p.trim());
        if (partes.length >= 5) {
            clientes.push({
                nome: partes[0],
                cpf: partes[1] || '',
                telefone: partes[2] || '',
                data_simulacao: parseData(partes[3]),
                valor: parseFloat(partes[4]?.replace(/\D/g, '')) || 0,
                prazo: parseInt(partes[5]) || 80,
                produto: partes[6] || 'Auto',
                canal: partes[7] || 'App'
            });
        }
    });
    
    if (clientes.length === 0) return showToast('Nenhum cliente encontrado nos dados', 'error');
    
    try {
        const res = await fetch('/api/reports', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': Bearer ${currentToken}
            },
            body: JSON.stringify({ nome, clientes })
        });
        
        const data = await res.json();
        
        if (res.ok) {
            showToast(${data.total} clientes processados!);
            document.getElementById('report-name').value = '';
            document.getElementById('report-data').value = '';
            loadReports();
            loadDashboard();
        } else {
            showToast(data.error || 'Erro ao processar', 'error');
        }
    } catch (err) {
        showToast('Erro de conexão', 'error');
    }
}

async function openReport(reportId, reportName) {
    currentReportId = reportId;
    document.getElementById('clients-report-name').textContent = reportName;
    showScreen('clients');
    loadClients('all');
}

function backToClients() {
    showScreen('clients');
}

async function loadClients(filter) {
    try {
        const res = await fetch(/api/reports/${currentReportId}/clients, {
            headers: { 'Authorization': Bearer ${currentToken} }
        });
        const clients = await res.json();
        currentClients = clients;
        
        let filtered = clients;
        if (filter === 'hoje') filtered = clients.filter(c => c.prioridade === 'hoje');
        if (filter === 'semana') filtered = clients.filter(c => c.prioridade === 'semana');
        if (filter === 'pendente') filtered = clients.filter(c => c.status === 'pendente');
        
        const container = document.getElementById('clients-list');
        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="empty-state">
                    <span>🔍</span>
                    <p>Nenhum cliente neste filtro</p>
                </div>
            `;
        } else {
            container.innerHTML = filtered.map(c => `
                <div class="client-card prioridade-${c.prioridade}" onclick="openClient(${c.id})">
                    <div class="client-card-header">
                        <span class="client-name">${c.nome}</span>
                        <span class="client-score ${c.score >= 85 ? 'alto' : c.score >= 70 ? 'medio' : ''}">${c.score}</span>
                    </div>
                    <div class="client-info">
                        <span class="client-badge badge-arquetipo">${c.arquetipo}</span>
                        <span class="client-badge badge-prioridade-${c.prioridade}">${getPrioridadeLabel(c.prioridade)}</span>
                    </div>
                    <div class="client-info">
                        <span>💰 ${formatCurrency(c.valor_simulado)}</span>
                        <span>📅 ${c.prazo} meses</span>
                        <span>📅 ${formatDateShort(c.data_simulacao)}</span>
                    </div>
                    <div class="client-phone">
                        <span>📞</span>
                        <span>${c.telefone || 'Sem telefone'}</span>
                    </div>
                </div>
            `).join('');
        }
        
        document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector([data-filter="${filter}"])?.classList.add('active');
    } catch (err) {
        console.error('Erro clients:', err);
    }
}

function filterClients(filter) {
    loadClients(filter);
}

