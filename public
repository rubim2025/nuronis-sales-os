let selectedResultado = null;

function selectResultado(resultado, el) {
    selectedResultado = resultado;
    document.querySelectorAll('.resultado-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    
    document.querySelectorAll('.form-extra').forEach(f => f.classList.add('hidden'));
    if (resultado === 'venda') document.getElementById('form-venda')?.classList.remove('hidden');
    if (resultado === 'perdeu') document.getElementById('form-perdeu')?.classList.remove('hidden');
}

async function submitResultado() {
    if (!selectedResultado) return showToast('Selecione um resultado', 'error');
    
    const usouRoteiro = document.querySelector('input[name="usou-roteiro"]:checked')?.value || 'sim';
    const valorVenda = document.getElementById('valor-venda')?.value?.replace(/\D/g, '');
    const motivoPerda = document.getElementById('motivo-perda')?.value;
    
    try {
        const res = await fetch(/api/clients/${currentClientId}/result, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': Bearer ${currentToken}
            },
            body: JSON.stringify({
                resultado: selectedResultado,
                valor_venda: valorVenda ? parseFloat(valorVenda) : null,
                motivo_perda: motivoPerda,
                usou_roteiro: usouRoteiro
            })
        });
        
        const data = await res.json();
        
        if (res.ok) {
            showToast(✅ +${data.tickets} tickets!);
            loadDashboard();
            backToClients();
        } else {
            showToast(data.error || 'Erro ao registrar', 'error');
        }
    } catch (err) {
        showToast('Erro de conexão', 'error');
    }
}

function copyText(btn) {
    const text = btn.parentElement.querySelector('.roteiro-text').textContent;
    navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copiado!';
        setTimeout(() => btn.textContent = 'Copiar', 2000);
    });
}

